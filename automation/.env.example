# Home Services Lead Machine — Configuration Template
# Copy this to .env and fill in your info, OR run: python setup/wizard.py
#
# NEVER commit .env to git — it contains your credentials

# Business Info
BUSINESS_NAME=Your Business Name
OWNER_NAME=Your Name
BUSINESS_CITY=Jacksonville
BUSINESS_STATE=FL
SERVICE_AREA=Jacksonville, Orange Park, Ponte Vedra, St. Augustine

# Phone Numbers
# TRACKING_PHONE = the number on your ads (AvidTrak, CallRail, etc.)
# PERSONAL_PHONE = your cell phone that receives forwarded calls
TRACKING_PHONE=9045550000
TRACKING_PROVIDER=avidtrak
PERSONAL_PHONE=9045551234

# Craigslist Accounts (need 2-3 for 7 ads/day)
# Each account needs: unique email, unique phone, unique proxy
CL_ACCOUNT_1_EMAIL=
CL_ACCOUNT_1_PASSWORD=
CL_ACCOUNT_1_PHONE=

CL_ACCOUNT_2_EMAIL=
CL_ACCOUNT_2_PASSWORD=
CL_ACCOUNT_2_PHONE=

CL_ACCOUNT_3_EMAIL=
CL_ACCOUNT_3_PASSWORD=
CL_ACCOUNT_3_PHONE=

# Proxy (ISP static residential — brightdata.com, oxylabs.io, or decodo.com)
# Get Jacksonville FL IPs for CL posting
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=

# GoLogin Anti-Detect Browser (gologin.com — $49/mo)
# Required for safe multi-account CL posting
# Get your API token from: app.gologin.com → Settings → API
GOLOGIN_API_TOKEN=
GOLOGIN_PROFILE_1=
GOLOGIN_PROFILE_2=
GOLOGIN_PROFILE_3=

# Facebook (for inbox monitor — optional)
FB_EMAIL=
FB_PASSWORD=
